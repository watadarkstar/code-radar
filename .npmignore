# Exclude all top-level hidden directories by convention
/.*/

# Exclude tarballs generated by `npm pack` / `yarn pack`
/*.tgz

# Source & tooling (publish built dist/ only; files field also controls this)
/src/
/tsconfig.json
/tsup.config.ts
/yarn.lock
/package-lock.json

# Local / generated
/node_modules/
/.code-radar/
*.log
.DS_Store
